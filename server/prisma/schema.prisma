generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id            String   @id @default(cuid())
  username      String   @unique
  password      String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  level         Int      @default(1)
  exp           Int      @default(0)
  hp            Int      @default(100)
  maxHp         Int      @default(100)
  mp            Int      @default(50)
  maxMp         Int      @default(50)
  gold          Int      @default(0)
  
  sp            Int      @default(0)
  str           Int      @default(10)
  agi           Int      @default(10)
  vit           Int      @default(10)
  
  hasBelt       Boolean  @default(false)
  questStatus   Int      @default(0)
  questProgress Int      @default(0)

}
